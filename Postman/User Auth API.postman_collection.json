    {
      "name": "04 - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "if (response.accessToken) {\r",
              "    pm.environment.set(\"access_token\", response.accessToken);\r",
              "    console.log(\"Access token saved to environment\");\r",
              "} else {\r",
              "    console.log(\"No access token in response\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
